VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Only needed for migration scripts (scripts/*.mjs)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
YPOTI_DEFAULT_PASSWORD=your-default-password-here

# Supabase Edge Function secrets (set via: supabase secrets set KEY=VALUE)
# Comma-separated list of allowed CORS origins for Edge Functions.
# Vercel preview domains (*.vercel.app) are always allowed by suffix match.
# ALLOWED_CORS_ORIGINS=https://sig-am.vercel.app,http://localhost:5173,http://localhost:3000
